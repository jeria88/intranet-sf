# Variables de entorno requeridas en Railway
# Copia este archivo a .env y completa los valores

# ── Seguridad ────────────────────────────────────
# Genera con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu-secret-key-aqui

# ── Entorno ──────────────────────────────────────
DEBUG=False

# ── Base de Datos PostgreSQL (Railway la provee automáticamente) ──
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# ── APIs de IA (Jornada 10+) ─────────────────────
# DeepSeek API (40 asesores IA por perfil)
DEEPSEEK_API_KEY=

# OpenAI Whisper API (transcripción de reuniones)
OPENAI_API_KEY=

# Anthropic Claude Haiku (actas automáticas)
ANTHROPIC_API_KEY=

# ── Daily.co (Videollamadas - Jornada 5) ─────────
DAILY_API_KEY=

# ── Cloudflare R2 (Videos - Jornada 6) ───────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=intranet-videos

# ── Dominio ───────────────────────────────────────
ALLOWED_HOSTS=tu-proyecto.railway.app,tudominio.cl
